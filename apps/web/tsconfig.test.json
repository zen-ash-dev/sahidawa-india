{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "node16",
        "moduleResolution": "node16",
        "rootDir": ".",
        "types": ["node", "jest"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": [
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "app/**/*.ts",
        "app/**/*.tsx",
        "lib/**/*.ts",
        "components/**/*.tsx"
    ]
}
