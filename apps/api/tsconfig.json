{
    "compilerOptions": {
        "isolatedModules": true,
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "node16",
        "ignoreDeprecations": "5.0",
        "rootDir": "./src",
        "outDir": "./dist",

        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,

        "esModuleInterop": true,
        "resolveJsonModule": true,

        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,

        "types": ["node"],

        "sourceMap": true,

        "declaration": true,

        "removeComments": false
    },

    "include": ["src/**/*"],

    "exclude": ["node_modules", "dist", "tests", ".tmp", "**/*.test.ts"]
}
